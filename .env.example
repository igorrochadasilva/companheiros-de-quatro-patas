CONTENTFUL_SPACE_ID=seu_space_id
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_DELIVERY_ACCESS_TOKEN=seu_delivery_access_token
CONTENTFUL_PREVIEW_ACCESS_TOKEN=seu_preview_access_token

NEXT_PUBLIC_SITE_URL=https://sua-url-publica.com

NEXT_PUBLIC_SUPABASE_URL=sua_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_supabase_anon_key
# Opcional (compatibilidade com prompt do Supabase):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sua_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=sua_supabase_service_role_key
ADMIN_EMAILS=admin@suaong.org,coordenacao@suaong.org

DATABASE_URL=sua_connection_string_postgres
DIRECT_URL=sua_connection_string_postgres_direta

CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_cloudinary_api_key
CLOUDINARY_API_SECRET=seu_cloudinary_api_secret

# Feature flags (publicas) - globais por dominio/feature.
# Aceita: true/false, 1/0, yes/no, on/off.
NEXT_PUBLIC_FLAG_ADOPTION=true
NEXT_PUBLIC_FLAG_SHELTER=false
NEXT_PUBLIC_FLAG_DONATE=false
NEXT_PUBLIC_FLAG_BAZAAR=false
NEXT_PUBLIC_FLAG_ABOUT=true
NEXT_PUBLIC_FLAG_CONTACT=true
NEXT_PUBLIC_FLAG_TRANSPARENCY=false

# Flags de secoes transversais
NEXT_PUBLIC_FLAG_HERO=true
NEXT_PUBLIC_FLAG_STORIES=true
NEXT_PUBLIC_FLAG_FAQ=true
